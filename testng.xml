<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Ecommerce Suite" parallel="tests" thread-count="4">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
<test name="Cart test">
        <classes>
            <class name="tests.CartTest"/>
        </classes>
</test>
    <test name="login test">
    <classes>
        <class name="tests.LoginTest">
        </class>
    </classes>
</test>
    <test name="search test">
        <classes>
            <class name="tests.ProductSearchTest">
            </class>
        </classes>
    </test>
    <test name="product test ">
        <classes>
            <class name="tests.ProductTest">
            </class>
        </classes>
    </test>
</suite>